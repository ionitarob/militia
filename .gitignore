Thumbs.db
*.swp

# ── IDEs ────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ── Flutter / Dart ──────────────────────────────────────────────────────
frontend/.dart_tool/
frontend/.flutter-plugins-dependencies
